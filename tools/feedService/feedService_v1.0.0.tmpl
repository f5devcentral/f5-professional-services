cli admin-partitions {
    update-partition Common
}

sys application template feedService_v1.0.0 {
    actions {
        definition {
            html-help {
            }
            implementation {

                set app_svc_version "1.0.0"

                # Check for required Tcl packages
                if { [catch {package require base64} pkg_err] } {
                    return -code error "Missing Tcl base64 package: $pkg_err"
                }

                # Validate that a given value is a valid BIG-IP object name
                proc validate_bigip_object_name {value field_name} {
                    if { ![regexp {^[A-Za-z][A-Za-z0-9_-]*$} $value] } {
                        return -code error "Invalid $field_name '$value'. Must start with a letter and contain only letters, numbers, underscores, or hyphens."
                    }
                }

                # Install embedded Python script to disk at deploy time
                proc install_script {target_path} {
                    set target_dir [file dirname $target_path]
                    if { ![file isdirectory $target_dir] } {
                        if { [catch {file mkdir $target_dir} mkdir_err] } {
                            return -code error "Unable to create directory $target_dir: $mkdir_err"
                        }
                    }

                    set py_b64_chunks {
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        ""
                        "Ujoge2Vycm9yX21lc3NhZ2V9IiwgZmlsZT1zeXMuc3RkZXJyKQogICAgICAgIHN5cy5leGl0KDEpCgppZiBfX25hbWVfXyA9PSAnX19tYWluX18nOgogICAgbWFpbigp"
                    }
                    set py_b64 [join $py_b64_chunks ""]
                    set py_text [base64::decode $py_b64]

                    set fh [open $target_path "w"]
                    fconfigure $fh -encoding utf-8 -translation lf
                    puts -nonewline $fh $py_text
                    close $fh

                    catch {exec chmod 0755 $target_path}
                }
                
                # Determine first occurrence based on frequency and time selections
                proc first_run {interval {hour 0} {day_of_week 0} {random_start 0}} {
                    set now [clock seconds]
                    switch -- $interval {
                        "hourly" {
                            scan [clock format $now -format "%M"] "%d" minute
                            scan [clock format $now -format "%S"] "%d" second
                            set next_epoch [expr { $now + 3600 - ($minute * 60 + $second) + $random_start }]
                            return [clock format $next_epoch -format "%Y-%m-%d:%H:%M"]
                        }
                        "daily" {
                            set today_str [clock format $now -format "%m/%d/%Y"]
                            set midnight  [clock scan $today_str]
                            set candidate [expr { $midnight + $hour * 3600 + $random_start }]
                            if { $candidate <= $now } {
                                set candidate [expr { $candidate + 86400 }]
                            }
                            return [clock format $candidate -format "%Y-%m-%d:%H:%M"]
                        }
                        "weekly" {
                            set current_dow [expr { int([clock format $now -format "%w"]) }]
                            set today_str   [clock format $now -format "%m/%d/%Y"]
                            set midnight    [clock scan $today_str]
                            set days_ahead  [expr { ($day_of_week - $current_dow + 7) % 7 }]
                            set candidate   [expr { $midnight + $days_ahead * 86400 + $hour * 3600 + $random_start }]
                            if { $candidate <= $now } {
                                set candidate [expr { $candidate + 7 * 86400 }]
                            }
                            return [clock format $candidate -format "%Y-%m-%d:%H:%M"]
                        }
                    }
                }

                # Escape special characters for JSON strings
                proc json_escape {s} {
                    set s [string map {\\ \\\\ \" \\\"} $s]
                    return $s
                }

                # Construct HTTP headers from provided arguments
                proc iapp_headers { args } {
                    set idx 0
                    set headers ""

                    foreach { match name value } [regexp -all -inline -line {header_name\s+(.+?)\s+header_value\s+(.+)$} $args] {
                        set hdr_name [string trim $name]
                        set hdr_value [string trim $value]
                        if { $hdr_name ne "" && $hdr_value ne "" } {
                            if { $idx == 0 } {
                                append headers "\n                \"[json_escape $hdr_name]\": \"[json_escape $hdr_value]\""
                            } else {
                                append headers ",\n                \"[json_escape $hdr_name]\": \"[json_escape $hdr_value]\""
                            }
                            incr idx
                        }
                    }
                    return $headers
                }

                # Construct a JSON list from provided arguments
                proc iapp_list { args } {
                    set items ""
                    set expect_item_value 0
                    foreach value [join $args] {
                        set value [string trim $value]
                        if { $value eq "" } {
                            continue
                        }

                        if { [regexp {(?s)^\{\s*item\s*\}$} $value] } {
                            set expect_item_value 0
                            continue
                        }

                        if { [regexp {(?s)^\{\s*item\s+(.+)\s*\}$} $value -> item_value] } {
                            set item_value [string trim $item_value]
                            if { $item_value ne "" } {
                                append items "\"[json_escape $item_value]\","
                            }
                            set expect_item_value 0
                            continue
                        }

                        if { $value eq "item" } {
                            set expect_item_value 1
                            continue
                        }

                        if { $expect_item_value } {
                            append items "\"[json_escape $value]\","
                            set expect_item_value 0
                            continue
                        }

                        if { $value eq "\{" || $value eq "\}" } {
                            continue
                        }

                        append items "\"[json_escape $value]\","
                    }
                    return [string trimright $items ","]
                }

                # Extract a specific section from a JSON string
                proc extract_json_section { json_text section_name } {
                    set token "\"$section_name\""
                    set token_index [string first $token $json_text]
                    if { $token_index < 0 } {
                        return ""
                    }

                    set brace_start [string first "\{" $json_text $token_index]
                    if { $brace_start < 0 } {
                        return ""
                    }

                    set depth 0
                    set length [string length $json_text]
                    for { set i $brace_start } { $i < $length } { incr i } {
                        set ch [string index $json_text $i]
                        if { $ch eq "\{" } {
                            incr depth
                        } elseif { $ch eq "\}" } {
                            incr depth -1
                            if { $depth == 0 } {
                                return [string range $json_text $brace_start $i]
                            }
                        }
                    }
                    return ""
                }

                # Set common variables
                set app_svc_name $tmsh::app_name
                set app_svc_path "/Common/${app_svc_name}.app"
                set ifile_config "${app_svc_name}.conf"
                set ifile_python "${app_svc_name}.py"
                set script_root "/shared/feedService"
                set script_dir "${script_root}/${app_svc_name}"
                set py_path "${script_dir}/${app_svc_name}.py"
                set is_initial_deploy 0

                # Ensure optional variables are defined
                if { ![info exists ::endpoint__username] } { set ::endpoint__username "" }
                if { ![info exists ::endpoint__password1] } { set ::endpoint__password1 "" }
                if { ![info exists ::endpoint__token] } { set ::endpoint__token "" }
                if { ![info exists ::endpoint__req_body] } { set ::endpoint__req_body "" }
                if { ![info exists ::endpoint__headers] } { set ::endpoint__headers "\[\]" }
                if { ![info exists ::endpoint__csv_position] } { set ::endpoint__csv_position 0 }
                if { ![info exists ::endpoint__csv_has_header] } { set ::endpoint__csv_has_header "false" }
                if { ![info exists ::endpoint__delimiter] } { set ::endpoint__delimiter "" }
                if { ![info exists ::endpoint__regex] } { set ::endpoint__regex "" }
                if { ![info exists ::endpoint__json_mode] } { set ::endpoint__json_mode "" }
                if { ![info exists ::endpoint__json_pointers] } { set ::endpoint__json_pointers "\[\]" }
                if { ![info exists ::endpoint__json_pointer_strict] } { set ::endpoint__json_pointer_strict "false" }
                if { ![info exists ::import__url_exclusions] } { set ::import__url_exclusions "\[\]" }
                if { ![info exists ::import__ip_exclusions] } { set ::import__ip_exclusions "\[\]" }
                if { ![info exists ::export__ucat_action] } { set ::export__ucat_action "allow" }
                if { ![info exists ::export__idg_combine] } { set ::export__idg_combine "true" }
                if { ![info exists ::export__url_inclusions] } { set ::export__url_inclusions "\[\]" }
                if { ![info exists ::export__ip_inclusions] } { set ::export__ip_inclusions "\[\]" }
                if { ![info exists ::export__ucat_name] } { set ::export__ucat_name "" }
                if { ![info exists ::export__ucat_custom] } { set ::export__ucat_custom "" }
                if { ![info exists ::export__udg_name] } { set ::export__udg_name "" }
                if { ![info exists ::export__udg_custom] } { set ::export__udg_custom "" }
                if { ![info exists ::export__idg_custom] } { set ::export__idg_custom "" }
                if { ![info exists ::export__idg_name] } { set ::export__idg_name "" }
                if { ![info exists ::schedule__random_start] } { set ::schedule__random_start "false" }
                if { ![info exists ::network__proxy_scheme] } { set ::network__proxy_scheme "" }
                if { ![info exists ::network__proxy_host] } { set ::network__proxy_host "" }
                if { ![info exists ::network__proxy_port] } { set ::network__proxy_port "" }
                if { ![info exists ::network__proxy_auth] } { set ::network__proxy_auth "none" }
                if { ![info exists ::network__proxy_username] } { set ::network__proxy_username "" }
                if { ![info exists ::network__proxy_password1] } { set ::network__proxy_password1 "" }
                if { ![info exists ::force_update__force] } { set ::force_update__force "no" }

                # Clear variables if they are not defined in the current deployment
                if { $::endpoint__auth eq "none" } {
                    set ::endpoint__username ""
                    set ::endpoint__password1 ""
                    set ::endpoint__token ""
                } elseif { $::endpoint__auth eq "basic" } {
                    set ::endpoint__token ""
                } elseif { $::endpoint__auth eq "token" } {
                    set ::endpoint__username ""
                    set ::endpoint__password1 ""
                }
                if { $::endpoint__method eq "GET" } {
                    set ::endpoint__req_body ""
                }
                if { $::network__proxy eq "false" } {
                    set ::network__proxy_scheme ""
                    set ::network__proxy_host ""
                    set ::network__proxy_port ""
                    set ::network__proxy_auth "none"
                }
                if { $::network__proxy_auth eq "none" } {
                    set ::network__proxy_username ""
                    set ::network__proxy_password1 ""
                }

                # Calculate random start offset (0-600 seconds) if enabled
                if { $::schedule__random_start eq "true" } {
                    set random_start [expr { int(rand() * 600) }]
                } else {
                    set random_start 0
                }

                # Calculate first occurrence and interval based on frequency selection
                if { $::schedule__frequency eq "hourly" } {
                    set first_run [first_run "hourly" 0 0 $random_start]
                    set interval 3600
                } elseif { $::schedule__frequency eq "daily" } {
                    set first_run [first_run "daily" $::schedule__hour 0 $random_start]
                    set interval 86400
                } elseif { $::schedule__frequency eq "weekly" } {
                    set first_run [first_run "weekly" $::schedule__hour $::schedule__day $random_start]
                    set interval 604800
                } elseif { $::schedule__frequency eq "interval" } {
                    set first_run [clock format [expr { [clock seconds] + ($::schedule__interval * 60) }] -format "%Y-%m-%d:%H:%M"]
                    set interval [expr { $::schedule__interval * 60 }]
                }

                # Set export object names based on import type and user selections
                if { ($::import__type eq "url" || $::import__type eq "both") && ($::export__type eq "ucat" || $::export__type eq "both") } {
                    if { $::export__ucat_name eq "auto" } {
                        set ::export__ucat_name "fS_$app_svc_name"
                    } elseif { $::export__ucat_name eq "custom" } {
                        set ::export__ucat_name $::export__ucat_custom
                    }
                } else {
                    set ::export__ucat_name ""
                }
                if { ($::import__type eq "url" || $::import__type eq "both") && ($::export__type eq "dg" || $::export__type eq "both") } {
                    if { $::export__udg_name eq "auto" } {
                        set ::export__udg_name "fS_$app_svc_name"
                    } elseif { $::export__udg_name eq "custom" } {
                        set ::export__udg_name $::export__udg_custom
                    }
                } else {
                    set ::export__udg_name ""
                }
                if { ($::import__type eq "ip" || $::import__type eq "both") } {
                    if { $::export__idg_name eq "auto" } {
                        set ::export__idg_name "fS_$app_svc_name"
                    } elseif { $::export__idg_name eq "custom" } {
                        set ::export__idg_name $::export__idg_custom
                    }
                } else {
                    set ::export__idg_name ""
                }

                if { $::import__type ne "ip" } {
                    if { $::export__type eq "ucat" || $::export__type eq "both" } {
                        validate_bigip_object_name $::export__ucat_name "Custom URL Category name"
                    }
                    if { $::export__type eq "dg" || $::export__type eq "both" } {
                        validate_bigip_object_name $::export__udg_name "URL Data Group name"
                    }
                }
                if { $::import__type ne "url" } {
                    validate_bigip_object_name $::export__idg_name "IP Data Group name"
                }

                if { $::exceptions__delta_value < 0 || $::exceptions__delta_value > 100 } {
                    return -code error "Delta value must be between 0 and 100."
                }

                ## Build JSON
                set json "{\n"
                append json "    \"system\": {\n"
                append json "        \"log\": {\n"
                append json "            \"level\": $::general__log_level\n"
                append json "        },\n"
                append json "        \"exceptions\": {\n"
                append json "            \"delta_value\": $::exceptions__delta_value,\n"
                append json "            \"delta_action\": \"$::exceptions__delta_action\"\n"
                append json "        },\n"
                append json "        \"network\": {\n"
                append json "            \"proxy\": {\n"
                append json "                \"scheme\": \"$::network__proxy_scheme\",\n"
                append json "                \"host\": \"[json_escape $::network__proxy_host]\",\n"
                append json "                \"port\": \"$::network__proxy_port\",\n"
                append json "                \"auth\": \"$::network__proxy_auth\",\n"
                append json "                \"username\": \"[json_escape $::network__proxy_username]\",\n"
                append json "                \"password\": \"[json_escape $::network__proxy_password1]\"\n"
                append json "            },\n"
                append json "            \"attempts\": $::network__retry_attempts,\n"
                append json "            \"delay\": $::network__retry_delay,\n"
                append json "            \"cafile\": \"[json_escape $::network__cafile]\"\n"
                append json "        },\n"
                append json "        \"sync_update\": $::ha__sync_update\n"
                append json "    },\n"
                append json "    \"feed\": {\n"
                append json "        \"name\": \"$app_svc_name\",\n"
                append json "        \"endpoint\": {\n"
                append json "            \"method\": \"$::endpoint__method\",\n"
                append json "            \"url\": \"[json_escape $::endpoint__url]\",\n"
                append json "            \"auth\": {\n"
                append json "                \"type\": \"$::endpoint__auth\",\n"
                append json "                \"credentials\": {\n"
                append json "                    \"username\": \"[json_escape $::endpoint__username]\",\n"
                append json "                    \"password\": \"[json_escape $::endpoint__password1]\",\n"
                append json "                    \"token\": \"[json_escape $::endpoint__token]\"\n"
                append json "                }\n"
                append json "            },\n"
                append json "            \"headers\": {"
                append json "[iapp_headers $::endpoint__headers]\n"
                append json "            },\n"
                append json "            \"body\": \"[json_escape $::endpoint__req_body]\"\n"
                append json "        },\n"
                append json "        \"source\": {\n"
                append json "            \"format\": \"$::endpoint__format\",\n"
                append json "            \"csv_position\": $::endpoint__csv_position,\n"
                append json "            \"csv_has_header\": $::endpoint__csv_has_header,\n"
                append json "            \"delimiter\": \"[json_escape $::endpoint__delimiter]\",\n"
                append json "            \"regex\": \"[json_escape $::endpoint__regex]\",\n"
                append json "            \"json_mode\": \"$::endpoint__json_mode\",\n"
                append json "            \"json_pointers\": \[[iapp_list $::endpoint__json_pointers]\],\n"
                append json "            \"json_pointer_strict\": $::endpoint__json_pointer_strict\n"
                append json "        },\n"
                append json "        \"import\": {\n"
                if { $::import__type eq "url" } {
                    append json "            \"ip_exclusions\": \[\],\n"
                    append json "            \"url_exclusions\": \[[iapp_list $::import__url_exclusions]\]\n"
                } elseif { $::import__type eq "ip" } {
                    append json "            \"ip_exclusions\": \[[iapp_list $::import__ip_exclusions]\],\n"
                    append json "            \"url_exclusions\": \[\]\n"
                } elseif { $::import__type eq "both" } {
                    append json "            \"ip_exclusions\": \[[iapp_list $::import__ip_exclusions]\],\n"
                    append json "            \"url_exclusions\": \[[iapp_list $::import__url_exclusions]\]\n"
                }
                append json "        },\n"
                append json "        \"export\": {\n"
                append json "            \"url\": {\n"
                append json "                \"category\": \"[json_escape $::export__ucat_name]\",\n"
                append json "                \"cataction\": \"[json_escape $::export__ucat_action]\",\n"
                append json "                \"datagroup\": \"[json_escape $::export__udg_name]\",\n"
                append json "                \"include\": \[[iapp_list $::export__url_inclusions]\]\n"
                append json "            },\n"
                append json "            \"ip\": {\n"
                append json "                \"datagroup\": \"[json_escape $::export__idg_name]\",\n"
                append json "                \"combine\": $::export__idg_combine,\n"
                append json "                \"include\": \[[iapp_list $::export__ip_inclusions]\]\n"
                append json "            }\n"
                append json "        }\n"
                append json "    }\n"
                append json "}\n"

                # Check if configuration iFile already exists to determine if this is an initial deployment or an update
                if {[catch {tmsh::list sys file ifile ${app_svc_path}/${ifile_config}}]} {
                    set is_initial_deploy 1
                }

                set offline_update 0
                if { !$is_initial_deploy } {
                    set existing_config_path [exec /bin/bash -c "find /config/filestore/files_d/Common_d/ifile_d -type f -path '*/:Common:${app_svc_name}.app:${app_svc_name}.conf_*_*' 2>/dev/null | sort -V | tail -n1"]
                    if { $existing_config_path ne "" && [file exists $existing_config_path] } {
                        if { [catch {
                            set existing_config_fh [open $existing_config_path "r"]
                            set existing_json [read $existing_config_fh]
                            close $existing_config_fh

                            set old_import [extract_json_section $existing_json "import"]
                            set old_export [extract_json_section $existing_json "export"]
                            set new_import [extract_json_section $json "import"]
                            set new_export [extract_json_section $json "export"]

                            if { $old_import ne $new_import || $old_export ne $new_export } {
                                set offline_update 1
                            }
                        } existing_cfg_err] } {
                            if { [info exists existing_config_fh] } {
                                catch {close $existing_config_fh}
                            }
                            set offline_update 0
                        }
                    }
                }

                set script_version_changed 0
                if { $is_initial_deploy } {
                    # On first deployment, delete any stale lastrun data group so the feed starts fresh
                    catch {tmsh::delete ltm data-group internal /Common/fS_${app_svc_name}_lastrun}

                    # On first deployment, remove any stale app directory and recreate it cleanly
                    if { [file exists $script_dir] } {
                        if { [catch {file delete -force $script_dir} delete_err] } {
                            return -code error "Unable to remove existing directory $script_dir: $delete_err"
                        }
                    }

                    set required_dirs [list \
                        $script_root \
                        $script_dir]
                    foreach dir $required_dirs {
                        if { ![file isdirectory $dir] } {
                            if { [catch {file mkdir $dir} mkdir_err] } {
                                return -code error "Unable to create directory $dir: $mkdir_err"
                            }
                        }
                    }

                    install_script $py_path

                } else {
                    # Not an initial deploy — compare the on-disk script version to app_svc_version
                    set script_version_changed 0
                    if { ![file exists $py_path] } {
                        # Script is missing from disk; reinstall it
                        set script_version_changed 1
                        install_script $py_path
                    } else {
                        if { [catch {
                            set ver_fh [open $py_path "r"]
                            set disk_version ""
                            set ver_found 0
                            while { [gets $ver_fh ver_line] >= 0 } {
                                if { [regexp {#\s*Version:\s*(\S+)} $ver_line -> disk_version] } {
                                    set ver_found 1
                                    break
                                }
                            }
                            close $ver_fh
                            if { $ver_found } {
                                if { $disk_version ne $app_svc_version } {
                                    set script_version_changed 1
                                }
                            } else {
                                # Version line not found; reinstall to be safe
                                set script_version_changed 1
                            }
                        } ver_err] } {
                            # Could not read file; reinstall to be safe
                            if { [info exists ver_fh] } { catch {close $ver_fh} }
                            set script_version_changed 1
                        }
                        if { $script_version_changed } {
                            # Suppress offline_update — a code change warrants a fresh fetch
                            set offline_update 0
                            install_script $py_path
                        }
                    }
                }

                # Import config as iFile so it can be sync'd across an HA pair
                set tmp_config "${script_dir}/.${ifile_config}"
                set tmp_config_fh [open ${tmp_config} "w"]
                puts ${tmp_config_fh} ${json}
                close ${tmp_config_fh}

                tmsh::create sys file ifile ${ifile_python} source-path file:${py_path} app-service ${app_svc_name}
                tmsh::create sys file ifile ${ifile_config} source-path file:${tmp_config} app-service ${app_svc_name}

                set icall_periodic_script [format {
                    catch { tmsh::show /sys failover } failover_check
                    if { $failover_check contains "standby" } {
                        return
                    }
                    set script_ifile [exec /bin/bash -c "find /config/filestore/files_d/Common_d/ifile_d -type f -path '*/:Common:%s.app:%s.py_*_*' 2>/dev/null | sort -V | tail -n1"]
                    if { ${script_ifile} ne "" } {
                        set script_dir "/shared/feedService/%s"
                        set script_shared "${script_dir}/%s.py"
                        # Bootstrap: ensure runtime directory exists
                        if { ![file isdirectory ${script_dir}] } {
                            catch { file mkdir ${script_dir} }
                        }
                        # Bootstrap: sync script from filestore if missing or outdated
                        if { ![file exists ${script_shared}] || [file mtime ${script_ifile}] > [file mtime ${script_shared}] } {
                            catch { file copy -force ${script_ifile} ${script_shared} }
                            catch { exec chmod 0755 ${script_shared} }
                        }
                        # Execute from shared if available, otherwise from filestore
                        if { [file exists ${script_shared}] } {
                            exec /usr/bin/python3 ${script_shared} > /dev/null 2>&1
                        } else {
                            exec /usr/bin/python3 ${script_ifile} > /dev/null 2>&1
                        }
                    } else {
                        exec logger -p local0.error "\[fS\] %s.app: Unable to find the Python iFile related to this application service. This error is unexpected, please open an Issue on the feedService project."
                    }
                } ${app_svc_name} ${app_svc_name} ${app_svc_name} ${app_svc_name} ${app_svc_name}]

                tmsh::create sys icall script ${app_svc_name}_periodic definition \{ ${icall_periodic_script} \} app-service ${app_svc_name}

                if { $::schedule__frequency ne "disabled" } {
                    tmsh::create sys icall handler periodic ${app_svc_name}_periodic interval ${interval} status active first-occurrence ${first_run} script ${app_svc_path}/${app_svc_name}_periodic app-service ${app_svc_name}
                }

                set icall_perpetual_script [format {
                    set script_ifile [exec /bin/bash -c "find /config/filestore/files_d/Common_d/ifile_d -type f -path '*/:Common:%s.app:%s.py_*_*' 2>/dev/null | sort -V | tail -n1"]
                    set script_dir "/shared/feedService/%s"
                    set script_shared "${script_dir}/%s.py"
                    set old_status unknown
                    if { [catch { tmsh::show /sys failover } failover_state_raw] == 0 } {
                        set failover_state_lc [string tolower $failover_state_raw]
                        if { $failover_state_lc contains "active" } {
                            set old_status active
                        } elseif { $failover_state_lc contains "standby" } {
                            set old_status standby
                        }
                    }
                    # Bootstrap on handler startup: ensure runtime directory and script are synced
                    if { ${script_ifile} ne "" } {
                        if { ![file isdirectory ${script_dir}] } {
                            catch { file mkdir ${script_dir} }
                        }
                        if { ![file exists ${script_shared}] || [file mtime ${script_ifile}] > [file mtime ${script_shared}] } {
                            catch { file copy -force ${script_ifile} ${script_shared} }
                            catch { exec chmod 0755 ${script_shared} }
                        }
                    }
                    while { 1 } {
                        set new_status ""
                        if { [catch { tmsh::show /sys failover } failover_state_raw] == 0 } {
                            set failover_state_lc [string tolower $failover_state_raw]
                            if { $failover_state_lc contains "active" } {
                                set new_status active
                            } elseif { $failover_state_lc contains "standby" } {
                                set new_status standby
                            }
                        }
                        if { $new_status eq "" } {
                            after 5000
                            continue
                        }
                        if { $new_status eq "active" && $old_status ne "active" } {
                            if { ${script_ifile} ne "" && [file exists ${script_shared}] } {
                                exec /usr/bin/python3 ${script_shared} > /dev/null 2>&1
                            } elseif { ${script_ifile} ne "" } {
                                exec /usr/bin/python3 ${script_ifile} > /dev/null 2>&1
                            } else {
                                exec logger -p local0.error "\[fS\] %s.app: Unable to find the Python iFile related to this application service. This error is unexpected, please open an issue on the feedService project."
                            }
                        }
                        set old_status $new_status
                        after 5000
                    }
                } ${app_svc_name} ${app_svc_name} ${app_svc_name} ${app_svc_name} ${app_svc_name}]

                tmsh::create sys icall script ${app_svc_name}_failover definition \{ ${icall_perpetual_script} \} app-service ${app_svc_name}

                if { $::ha__run_failover eq "true" } {
                    tmsh::create sys icall handler perpetual ${app_svc_name}_perpetual status active script ${app_svc_path}/${app_svc_name}_failover app-service ${app_svc_name}
                } else {
                    tmsh::create sys icall handler perpetual ${app_svc_name}_perpetual status inactive script ${app_svc_path}/${app_svc_name}_failover app-service ${app_svc_name}
                }

                if { ( $is_initial_deploy && $::schedule__frequency ne "disabled" ) || $::force_update__force == "yes" || $offline_update || $script_version_changed } {
                    set py_path "/shared/feedService/${app_svc_name}/${app_svc_name}.py"
                    set force_flag ""
                    set offline_flag ""

                    # Encode JSON on a single line so it survives shell argument parsing.
                    set json_b64 [base64::encode -maxlen 0 ${json}]
                    regsub -all {\r|\n} $json_b64 "" json_b64

                    if { $::force_update__force == "yes" || $script_version_changed } {
                        set force_flag "--force "
                    }

                    if { $offline_update && $::force_update__force != "yes" } {
                        set offline_flag "--offline-update "
                    }

                    # Pass base64-encoded JSON directly to script via --config-json argument.
                    # This avoids a race condition where the script attempts to read the iFile
                    # before it's deployed or updated by the application service
                    set cmd "( /usr/bin/python3 ${py_path} ${force_flag}${offline_flag}--config-json \"${json_b64}\" > /dev/null 2>&1 ) &"

                    if {[catch {exec /bin/bash -c $cmd} e]} {
                        return -code error "Failed to run feedService: $e"
                    }

                }

                # Remove temporary config file
                file delete ${tmp_config}

            }
            macro {
            }
            presentation {
                
                section general {
                    choice help default "yes" display "small" { "No" => "no", "Yes" => "yes" }
                    choice log_level default "2" display "large" { "1 - Error" => "1", "2 - Info" => "2", "3 - Debug" => "3" }
                    optional ( general.help == "yes" ) {
                        message log_level_help "Defines the logging level - useful for monitoring & troubleshooting purposes."
                        message log_level_help_1 "1 - Error: Only failures and critical run status."
                        message log_level_help_2 "2 - Info: Normal operations, summaries, warnings, and successful update/sync messages."
                        message log_level_help_3 "3 - Debug: Detailed trace (per-entry processing, classification, request metadata, hash/comparison details)."
                    }
                }

                section endpoint {
                    choice method default "GET" display "medium" { "GET" => "GET", "POST" => "POST" }
                    optional ( general.help == "yes" ) {
                        message method_help "Defines the HTTP method to use for fetching the feed. Select 'GET' for standard feed retrieval or 'POST' if the feed requires a POST request."
                    }
                    string url display "xxlarge" required
                    optional ( general.help == "yes" ) {
                        message url_help "Defines the URL for the HTTP request. This should be the full URL of the feed, including protocol/scheme (e.g. https://example.com/feed.txt)."
                    }
                    choice auth default "none" { "None" => "none", "Basic" => "basic", "Bearer Token" => "bearer" }
                    optional ( general.help == "yes" ) {
                        message auth_help "Defines the authentication method used for the feed fetch request. Select 'None' if the feed does not require authentication, 'Basic' to use a username and password, or 'Bearer Token' to use a token in the Authorization header."
                    }
                    optional ( auth == "basic" ) {
                        string username required
                        optional ( general.help == "yes" ) {
                            message username_help "Defines the username used for Basic authentication."
                        }
                        password password1 required
                        optional ( general.help == "yes" ) {
                            message password1_help "Defines the password used for Basic authentication. Note: the password value will be stored in plaintext in the application service iFile and may be viewable by users with access to the BIG-IP filesystem or application service configuration. Ensure appropriate precautions are taken to protect sensitive information when using this authentication method."
                        }
                    }
                    optional ( auth == "bearer" ) {
                        password token required display "large"
                        optional ( general.help == "yes" ) {
                            message token_help "Defines the Bearer token to include in the Authorization header for feed fetch requests when using Bearer Token authentication. Note: the token value will be stored in plaintext in the application service iFile and may be viewable by users with access to the BIG-IP filesystem or application service configuration. Ensure appropriate precautions are taken to protect sensitive information when using this authentication method."
                        }
                    }
                    table headers {
                        string header_name display "large"
                        string header_value display "large"
                    }
                    optional ( general.help == "yes" ) {
                        message headers_help "Defines one or more custom HTTP headers to include in the HTTP request. This optional setting can be used to include any additional headers required by the feed provider. Only static values are supported."
                    }
                    optional ( method == "POST" ) {
                        string req_body display "xxlarge"
                        optional ( general.help == "yes" ) {
                            message req_body_help "Defines the request body to include in the HTTP request when using the POST method. This is optional and can be left blank for feeds that do not require a request body."
                        }
                    }
                    choice format default "line" { "Line-separated" => "line", "CSV" => "csv", "Delimited" => "delimited", "JSON" => "json", "Regex" => "regex" }
                    optional ( general.help == "yes" ) {
                        message format_help "Defines the expected format of the feed data. Line-separated: the feed contains one feed item (i.e. URL or IP) per line. CSV: the feed is in CSV (comma-separated) format. Delimited: the feed items are separated by a custom delimiter. JSON: use one or more JSON pointers (RFC 6901) to extract feed items from JSON documents. Regex: use a custom regular expression to extract feed items from the feed data."
                    }
                    optional ( format == "csv" ) {
                        string csv_position default "0" display "small" required
                        optional ( general.help == "yes" ) {
                            message csv_position_help "Defines the zero-based position of the column containing feed items. For example, if the feed items are in the first column, enter '0'. If they are in the second column, enter '1', and so on."
                        }

                        choice csv_has_header default "false" display "small" { "No" => "false", "Yes" => "true" }
                        optional ( general.help == "yes" ) {
                            message csv_has_header_help "When enabled, the first CSV row is treated as a header row and skipped during import."
                        }
                    }
                    optional ( format == "delimited" ) {
                        string delimiter default ";" display "small" required
                        optional ( general.help == "yes" ) {
                            message delimiter_help "Defines the delimiter separating the feed items. This is required when the feed uses a custom delimiter other than line breaks and commas. For example, if the feed items are separated by semicolons, enter ';' as the delimiter."
                        }
                    }
                    optional ( format == "regex" ) {
                        string regex display "large" required
                        optional ( general.help == "yes" ) {
                            message regex_help "Defines the regular expression used to match feed items. Only items matching this regex will be imported."
                        }
                    }
                    optional ( format == "json" ) {
                        choice json_mode default "pointers" display "large" { "Use JSON Pointers" => "pointers", "Extract Entire Document" => "document" }
                        optional ( general.help == "yes" ) {
                            message json_mode_help "Controls how JSON data is extracted. 'Use JSON Pointers' extracts only selected JSON paths. 'Extract Entire Document' recursively scans the full JSON document and extracts all string values."
                        }
                        optional ( json_mode == "pointers" ) {
                            table json_pointers { string item display "xxlarge" required }
                        }
                        optional ( general.help == "yes" && json_mode == "pointers" ) {
                            message json_pointers_help "Defines one or more JSON pointers used to extract values from a JSON feed payload. Data from all configured pointers is merged. Examples: '/indicators', '/data/items', '/results/0/value'."
                        }
                        optional ( json_mode == "pointers" ) {
                            choice json_pointer_strict default "false" display "small" { "No" => "false", "Yes" => "true" }
                        }
                        optional ( general.help == "yes" && json_mode == "pointers" ) {
                            message json_pointer_strict_help "When enabled, all configured JSON pointers must resolve and return one or more values or the run fails. When disabled, unresolved or empty pointers are logged and skipped."
                        }
                    }
                }

                section import {
                    choice type default "both" display "large" { "Only IPs" => "ip", "Only Domains" => "url", "IPs and Domains" => "both" }
                    optional ( general.help == "yes" ) {
                        message type_help "Defines the type of feed data to import and process. Select 'Only IPs' to import and process only IP addresses, 'Only Domains' to import and process only domains, or 'IPs and Domains' to import and process both IP addresses and domains."
                    }
                    optional ( type != "url" ) {
                        table ip_exclusions { string item display "large" validator "IpAddress" }
                        optional ( general.help == "yes" ) {
                            message ip_exclusions_help "Defines IP addresses/subnets to exclude/remove from the imported feed data. Matching items will not be imported into the Data Group. Supports subnet pattern matching (e.g., '10.0.0.0/8' excludes all IPs in that subnet)."
                        }
                    }
                    optional ( type != "ip" ) {
                        table url_exclusions { string item display "large" }
                        optional ( general.help == "yes" ) {
                            message url_exclusions_help "Defines domains to exclude/remove from the imported feed data. These will not be imported into the URL Category / Data Group. Supports wildcard pattern matching (e.g., '*.example.com' excludes all subdomains of example.com)."
                        }
                    }
                }

                section export {
                    optional ( import.type != "ip" ) {
                        choice type default "dg" { "Custom URL Category" => "ucat", "Data Group" => "dg", "Both" => "both" }
                        optional ( general.help == "yes" ) {
                            message type_help_1 "Defines the type of BIG-IP object(s) to load the domains into."
                            message type_help_2 "Both: domains are imported into a Custom URL Category and Data Groups. Data Group: domains are imported into Data Groups only. Custom URL Category: domains are imported into a Custom URL Category only."
                        }
                        optional ( type != "dg" ) {
                            choice ucat_name default "auto" display "medium" { "Automatic" => "auto", "Custom" => "custom" }
                            optional ( general.help == "yes" ) {
                                message ucat_name_help_1 "Defines the name of the Custom URL Category that will store the domains."
                                message ucat_name_help_2 "Automatic: the Custom URL Category is named after the application service, with 'fS_' prepended to the name (e.g., fS_MyFeed). Custom: enter the name that will be assigned to the Custom URL Category."
                            }
                            optional ( ucat_name == "custom" ) {
                                string ucat_custom display "medium" required
                                message ucat_custom_alert "Loading large Custom URL Categories (more than ~1000 domains) can result in temporary interruptions to the control / management plane of the BIG-IP. While this does not impact traffic processing / the data plane, if the script is expected to handle large datasets it would be advisable to use Data Groups instead, or schedule the script to run when the control / management plane of the BIG-IP is least likely to be used (ex. after hours). This bottleneck can be somewhat mitigated on TMOS 21.0+ by increasing the number of threads available to MCPD."
                                optional ( general.help == "yes" ) {
                                    message ucat_custom_help "Defines the Custom URL Category name. Note: ensure that the name does not conflict with existing URL Categories on the BIG-IP and follows BIG-IP naming requirements."
                                }
                            }

                        }
                        optional ( type != "ucat" ) {
                            choice udg_name default "auto" display "medium" { "Automatic" => "auto", "Custom" => "custom" }
                            optional ( general.help == "yes" ) {
                                message udg_name_help_1 "Defines the name of the Data Groups that will store the downloaded domains. Separate Data Groups are created for exact matches such as 'www.example.com' (_exact), leading wildcards such as '*.example.com' (_endswith), trailing wildcards such as 'example.*' (_startswith), and bookended wildcards such as '*.example.*' (_contains)."
                                message udg_name_help_2 "Automatic: the Data Groups are named after the application service, with 'fS_' prepended to the name and the applicable matching type appended (e.g., fS_MyFeed_endswith). Custom: a user-defined name is assigned to the Data Groups with the applicable matching type appended (e.g., MyCustomName_endswith)."
                            }
                            optional ( udg_name == "custom" ) {
                                string udg_custom display "medium" required
                                optional ( general.help == "yes" ) {
                                    message udg_custom_help "A user-defined name will be assigned to the Data Groups with the applicable matching type appended (ex. MyCustomName_endswith). Note: ensure that the name does not conflict with existing Data Groups on the BIG-IP and follows BIG-IP naming requirements."
                                }
                            }
                        }
                        table url_inclusions { string item display "large" }
                        optional ( general.help == "yes" ) {
                            message url_inclusions_help "Defines domains to include in the Custom URL Category / Data Groups. Valid domains include non-wildcard domains such as 'www.example.com' and 'example.com', domains with leading wildcards such as '*.example.com', domains with trailing wildcards such as 'example.*', and domains bookended by wildcards, such as '*.example.*'. These are added in addition to feed data and only after exclusions are applied."
                        }
                    }
                    optional ( import.type != "url" ) {
                        choice idg_name default "auto" display "medium" { "Automatic" => "auto", "Custom" => "custom" }
                        optional ( general.help == "yes" ) {
                            message idg_name_help_1 "Defines the name of the Data Group(s) that will store the downloaded IP addresses and subnets."
                            message idg_name_help_2 "Automatic: the Data Group(s) are named after the application service, with 'fS_' prepended to the name. Custom: a user-defined name is assigned to the Data Group(s). Note: the Data Group name(s) are affected by the 'Combine IPv4 and IPv6' setting."
                        }
                        optional ( idg_name == "custom" ) {
                            string idg_custom display "medium" required
                            optional ( general.help == "yes" ) {
                                message idg_custom_help "Defines the custom IP Data Group base name. Note: ensure that the name does not conflict with existing Data Groups on the BIG-IP and follows BIG-IP naming requirements."
                            }
                        }

                        choice idg_combine display "small" default "true" { "No" => "false", "Yes" => "true" }
                        optional ( general.help == "yes" ) {
                            message idg_combine_help "IPv4 and IPv6 addresses can coexist in a single datagroup ending in '_ip' (Yes) or be separated into IPv4 ('_ipv4') and IPv6 ('_ipv6') data groups (No)."
                        }
                        table ip_inclusions { string item display "large" validator "IpAddress" }
                        optional ( general.help == "yes" ) {
                            message ip_inclusions_help "Defines IP addresses and subnets to include in the IP Data Group(s). Valid values include individual addresses such as '192.168.1.1' and subnets such as '192.168.1.0/24'. These are added in addition to feed data and only after exclusions are applied."
                        }
                    }
                }

                section schedule {
                    choice frequency display "large" default "daily" { "Disabled" => "disabled", "Hourly" => "hourly", "Daily" => "daily", "Weekly" => "weekly", "Interval (minutes)" => "interval" }
                    optional ( general.help == "yes" ) {
                        message frequency_help "Defines the frequency at which the feed is fetched and processed. Disabled: disables scheduled updates (on-demand/unscheduled updates can be invoked via the Force update of feed data option). Hourly: every hour on the hour. Daily: once per day at the selected hour. Weekly: once per week on the selected day of week and hour. Interval (minutes): fetch and process the feed at a fixed interval, specified in minutes."
                    }
                    optional ( frequency == "weekly" ) {
                        choice day default "0" { "Monday" => "1", "Tuesday" => "2", "Wednesday" => "3", "Thursday" => "4", "Friday" => "5", "Saturday" => "6", "Sunday" => "0" }
                        optional ( general.help == "yes" ) {
                            message day_help "Defines the day of the week that the feed will be fetched and processed."
                        }
                    }
                    optional ( frequency == "daily" || frequency == "weekly" ) {
                        choice hour default "2" display "small" { "00:00" => "0", "01:00" => "1", "02:00" => "2", "03:00" => "3", "04:00" => "4", "05:00" => "5", "06:00" => "6", "07:00" => "7", "08:00" => "8", "09:00" => "9", "10:00" => "10", "11:00" => "11", "12:00" => "12", "13:00" => "13", "14:00" => "14", "15:00" => "15", "16:00" => "16", "17:00" => "17", "18:00" => "18", "19:00" => "19", "20:00" => "20", "21:00" => "21", "22:00" => "22", "23:00" => "23" }
                        optional ( general.help == "yes" ) {
                            message hour_help "Defines the hour of the day that the feed will be fetched and processed. For daily frequency, this will occur every day at the selected hour. For weekly frequency, this will occur on the selected day of week and hour."
                        }
                    }
                    optional ( frequency == "interval" ) {
                        string interval default "60" display "small" required
                        optional ( general.help == "yes" ) {
                            message interval_help "Defines the interval, in minutes, at which the feed will be fetched and processed."
                        }
                    }
                    optional ( frequency != "disabled" && frequency != "interval" ) {
                        choice random_start default "true" display "small" { "No" => "false", "Yes" => "true" }
                        optional ( general.help == "yes" ) {
                            message random_start_help "When enabled, feedService adds a randomized start offset of 0-10 minutes to scheduled runs to reduce burst load when many feeds are scheduled at the same time. This option is only available for hourly, daily, and weekly frequencies."
                        }
                    }
                }

                section network {
                    choice proxy default "none" display "small" { "No" => "false", "Yes" => "true" }
                    optional ( general.help == "yes" ) {
                        message proxy_help "Defines whether feedService should use an explicit proxy for feed downloads. When enabled, configure proxy scheme, host, port, and optional Basic authentication credentials."
                    }
                    optional ( proxy == "true" ) {
                        choice proxy_scheme default "http" display "medium" { "HTTP" => "http", "HTTPS" => "https" }
                        optional ( general.help == "yes" ) {
                            message proxy_scheme_help "Defines the protocol/scheme to use for the proxy server. HTTP: uses the HTTP protocol. HTTPS: uses the HTTPS protocol."
                        }
                        string proxy_host display "large" required validator "IpOrFqdn"
                        optional ( general.help == "yes" ) {
                            message proxy_host_help "Defines the hostname or IP address of the proxy server."
                        }
                        string proxy_port display "small" required validator "NonNegativeNumber" default "3128"
                        optional ( general.help == "yes" ) {
                            message proxy_port_help "Defines the port number of the proxy server."
                        }
                        choice proxy_auth default "none" display "small" { "None" => "none", "Basic" => "basic" }
                        optional ( general.help == "yes" ) {
                            message proxy_auth_help "Defines the authentication method used for the proxy server. None: no authentication is used. Basic: uses a username and password for authentication."
                        }
                        optional ( proxy_auth == "basic" ) {
                            string proxy_username display "medium" required
                            optional ( general.help == "yes" ) {
                                message proxy_username_help "Defines the username used for Basic authentication with the proxy server."
                            }
                            password proxy_password1 display "medium" required
                            optional ( general.help == "yes" ) {
                                message proxy_password1_help "Defines the password used for Basic authentication with the proxy server. Note: the password value will be stored in plaintext in the application service iFile and may be viewable by users with access to the BIG-IP filesystem or application service configuration. Ensure appropriate precautions are taken to protect sensitive information when using this authentication method."
                            }
                        }
                    }
                    string retry_attempts default "3" display "small" required validator "NonNegativeNumber"
                    optional ( general.help == "yes" ) {
                        message retry_attempts_help "Defines the number of retry attempts when attempting to fetch the feed. This counter resets on each scheduled interval."
                    }
                    string retry_delay default "5" display "small" required validator "NonNegativeNumber"
                    optional ( general.help == "yes" ) {
                        message retry_delay_help "Defines the delay in seconds between retry attempts."
                    }
                    choice cafile default "ca-bundle.crt" tcl {
                        set objs [tmsh::get_config /sys crypto cert]
                        foreach obj $objs {
                            append results [tmsh::get_name $obj]
                            append results "\n"
                        }
                        return $results
                    }
                    optional ( general.help == "yes" ) {
                        message cafile_help "Defines the CA bundle file or trust store to use for validating the feed's TLS certificate. The default 'ca-bundle.crt' is sufficient for most use cases."
                    }
                }

                section exceptions {
                    string delta_value default "75" display "small" required validator "NonNegativeNumber"
                    optional ( general.help == "yes" ) {
                        message delta_value_help "Defines the acceptable delta (as a percentage) before triggering an action. If the number of feed items (i.e. Domains and/or IPs) drops by more than this percentage, compared to the previous successful fetch, it may indicate an issue with the feed (e.g. malformed response, temporary service issue, or a legitimate but significant change in the feed data)."
                    }
                    choice delta_action default "log" { "Ignore" => "ignore", "Log" => "log", "Abort" => "abort" }
                    optional ( general.help == "yes" ) {
                        message delta_action_help "Defines the action to take if the delta is exceeded. Ignore: import the feed data and do not log the exception. Log: import the feed data and log the exception. Abort: do not import the feed data and log the exception."
                    }
                }

                section ha {
                    choice sync_update display "small" default "false" { "No" => "false", "Yes" => "true" }
                    optional ( general.help == "yes" ) {
                        message sync_update_help "When enabled, feedService triggers a ConfigSync operation after successful BIG-IP object updates. This sync includes all pending configuration changes on the active BIG-IP, not only feedService-managed objects. Do not enable this option if Automatic Sync is enabled on the device group."
                    }
                    choice run_failover display "small" default "false" { "No" => "false", "Yes" => "true" }
                    optional ( general.help == "yes" ) {
                        message run_failover_help "When enabled, feedService runs when the device transitions to active state to reduce the chance of stale data after failover."
                    }
                }

                section force_update {
                    choice force default "no" { "No" => "no", "Yes" => "yes" }
                    optional ( general.help == "yes" ) {
                        message force_help "Forces an immediate update of the feed data. This is useful for testing and troubleshooting, and bypasses hash-based no-change skipping so processing continues even when the feed hash matches the previous successful run."
                    }
                }

                text {
                    general "General"
                    general.help "Show Help Text"
                    general.log_level "Log Level"
                    general.log_level_help ""
                    general.log_level_help_1 ""
                    general.log_level_help_2 ""
                    general.log_level_help_3 ""
                    endpoint "Feed Source"
                    endpoint.method "HTTP Method"
                    endpoint.method_help ""
                    endpoint.url "Feed URL"
                    endpoint.url_help ""
                    endpoint.auth "Feed Authentication"
                    endpoint.auth_help ""
                    endpoint.username "Username"
                    endpoint.username_help ""
                    endpoint.password1 "Password"
                    endpoint.password1_help ""
                    endpoint.token "Bearer Token"
                    endpoint.token_help ""
                    endpoint.headers "Custom Headers"
                    endpoint.headers_help ""
                    endpoint.headers.header_name "Name:"
                    endpoint.headers.header_value "Value:"
                    endpoint.req_body "Request Body"
                    endpoint.req_body_help ""
                    endpoint.format "Feed Format"
                    endpoint.format_help ""
                    endpoint.csv_position "CSV Position (Column)"
                    endpoint.csv_position_help ""
                    endpoint.csv_has_header "CSV Has Header Row"
                    endpoint.csv_has_header_help ""
                    endpoint.delimiter "Delimiter"
                    endpoint.delimiter_help ""
                    endpoint.regex "Regex Pattern"
                    endpoint.regex_help ""
                    endpoint.json_mode "JSON Extraction Mode"
                    endpoint.json_mode_help ""
                    endpoint.json_pointers "JSON Pointers"
                    endpoint.json_pointers_help ""
                    endpoint.json_pointers.item "Pointer:"
                    endpoint.json_pointer_strict "Strict Mode (JSON)"
                    endpoint.json_pointer_strict_help ""
                    import "Feed Parsing & Filtering"
                    import.type "Import from Feed"
                    import.type_help ""
                    import.ip_exclusions "IP Exclusions"
                    import.ip_exclusions_help ""
                    import.ip_exclusions.item "IP/Subnet:"
                    import.url_exclusions "Domain Exclusions"
                    import.url_exclusions_help ""
                    import.url_exclusions.item "Domain:"
                    export "BIG-IP Objects & Output"
                    export.type "Domain Object Type(s)"
                    export.type_help_1 ""
                    export.type_help_2 ""
                    export.ucat_name "Custom URL Category Name"
                    export.ucat_custom_alert ""
                    export.ucat_name_help_1 ""
                    export.ucat_name_help_2 ""
                    export.ucat_custom "Specify Name"
                    export.ucat_custom_help ""
                    export.udg_name "URL Data Group Name"
                    export.udg_name_help_1 ""
                    export.udg_name_help_2 ""
                    export.udg_custom "Specify Name"
                    export.udg_custom_help ""
                    export.url_inclusions "Domain Inclusions"
